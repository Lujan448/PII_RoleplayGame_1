namespace Library;

public class Archer
{
    private string name; //nombre del arquero
    private int health; //vida actual del arquero
    private int maxHealth; //vida maxima
    private List<Item> items;// Lista de objetos (arco, daga)

    public Archer(string name)
    {
        this.name = name;
        this.health = 100;
        this.maxHealth = 100;
        this.items = new List<Item>();//se crea lista de items

        this.items.Add(new Bow());//el arquero empieza con el arco y la daga
        this.items.Add(new Dagger());
    }

    public string Name
    {
        get { return this.name; }
    }

    public int Health
    {
        get { return this.health; }
    }

    public void AddItem(Item item)
    {
        this.items.Add(item);
    }

    public void RemoveItem(Item item)
    {
        this.items.Remove(item);
    }

    public int GetAttackValue()
    {
        int total = 0;

        foreach (Item item in this.items)
        {
            total += item.Attack;
        }

        return total;
    }

    public int GetDefenseValue()
    {
        int total = 0;

        foreach (Item item in this.items)
        {
            total += item.Defense;
        }

        return total;
    }

    public void ReceiveAttack(int damage)
    {
        int finalDamage = damage - this.GetDefenseValue();//se Descuenta el daño a la defensa

        if (finalDamage < 0)//nunca daño negativo
        {
            finalDamage = 0;
        }

        this.health -= finalDamage;//baja la vida

        if (this.health < 0)
        {
            this.health = 0;
        }
    }

    public void Attack(Archer enemy)
    {
        enemy.ReceiveAttack(this.GetAttackValue());
    }

    public void Heal()//se cura
    {
        this.health = this.maxHealth;
    }
}